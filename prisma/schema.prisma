generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL")
}

model Item {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  quantity    Int      @default(0)
  sku         String?  @unique
  barcode     String?  @unique
  imageUrl    String?
  status      String   @default("AVAILABLE") // AVAILABLE, IN_USE, MAINTENANCE, LOST
  
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  Int
  
  location    Location @relation(fields: [locationId], references: [id])
  locationId  Int

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  items       Item[]
}

model Location {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  type        String   @default("WAREHOUSE") // WAREHOUSE, VEHICLE, SITE
  items       Item[]
}
