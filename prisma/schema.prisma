generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL")
}

model Item {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  quantity    Int      @default(0)
  sku         String?  @unique
  barcode     String?  @unique
  imageUrl    String?
  status      String   @default("AVAILABLE") // AVAILABLE, IN_USE, MAINTENANCE, LOST
  siteKitSku  String?  // Optional Site Kit SKU
  
  // Material-specific fields
  unitType    String?  // UNIT, BOX
  unitsPerBox Int?     // For materials sold in boxes
  totalUnits  Int?     // Calculated total units
  
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  Int
  
  location    Location @relation(fields: [locationId], references: [id])
  locationId  Int

  serialNumbers SerialNumber[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SerialNumber {
  id            Int      @id @default(autoincrement())
  serialNumber  String?  // Regular serial number
  tmoSerial     String?  // T-Mobile serial number
  
  item          Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId        Int

  createdAt     DateTime @default(now())
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  items       Item[]
}

model Location {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  type        String   @default("WAREHOUSE") // WAREHOUSE, VEHICLE, SITE
  subcategory String?  // For areas like "Box 1", "Personal Milwaukee Box", etc.
  items       Item[]
}
