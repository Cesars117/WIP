generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL")
}

model Item {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  quantity    Int      @default(0)
  sku         String?  @unique
  barcode     String?  @unique
  imageUrl    String?
  status      String   @default("AVAILABLE") // AVAILABLE, IN_USE, MAINTENANCE, LOST
  siteKitSku  String?  // Optional Site Kit SKU
  
  // Material-specific fields
  unitType    String?  // UNIT, BOX
  unitsPerBox Int?     // For materials sold in boxes
  totalUnits  Int?     // Calculated total units
  
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  Int
  
  location    Location @relation(fields: [locationId], references: [id])
  locationId  Int

  serialNumbers SerialNumber[]
  siteKitAssetTags SiteKitAssetTag[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SerialNumber {
  id            Int      @id @default(autoincrement())
  serialNumber  String?  // Regular serial number
  tmoSerial     String?  // T-Mobile serial number
  
  item          Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId        Int
  siteKitAssetTags SiteKitAssetTag[]

  createdAt     DateTime @default(now())
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  items       Item[]
}

model Location {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  type        String   @default("WAREHOUSE") // WAREHOUSE, VEHICLE, SITE
  subcategory String?  // For areas like "Box 1", "Personal Milwaukee Box", etc.
  items       Item[]
}

// --- Audit Log ---
model AuditLog {
  id            Int      @id @default(autoincrement())
  userId        String
  userEmail     String?
  userName      String?
  action        String   // CREATED, UPDATED, DELETED, STATUS_CHANGED, QTY_CHANGED, VERIFIED, LINKED
  entityType    String   // ITEM, SERIAL_NUMBER, SITE_KIT, SITE_KIT_ITEM, ASSET_TAG
  entityId      Int
  entityLabel   String?
  fieldChanged  String?
  oldValue      String?
  newValue      String?
  metadata      Json?
  createdAt     DateTime @default(now())
}

// --- T-Mobile BOM / Site Kits ---
model SiteKit {
  id            Int       @id @default(autoincrement())
  siteKitId     String    @unique  // e.g. "SITEKIT_HNYH0Q4_12"
  bomId         String?
  siteId        String?
  projectName   String?
  pallets       Int?
  authNumber    String?
  mslLocation   String?
  company       String?
  catsCode      String?
  subcontractor String?
  dateCompleted DateTime?
  status        String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETE, DISCREPANCY
  items         SiteKitItem[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SiteKitItem {
  id               Int       @id @default(autoincrement())
  siteKit          SiteKit   @relation(fields: [siteKitId], references: [id], onDelete: Cascade)
  siteKitId        Int
  siteKitSku       String
  description      String
  quantityExpected Int
  quantityReceived Int       @default(0)
  status           String    @default("PENDING") // PENDING, VERIFIED, MISSING, SURPLUS, PARTIAL
  notes            String?
  assetTags        SiteKitAssetTag[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model SiteKitAssetTag {
  id              Int           @id @default(autoincrement())
  siteKitItem     SiteKitItem   @relation(fields: [siteKitItemId], references: [id], onDelete: Cascade)
  siteKitItemId   Int
  assetTag        String        // TM########
  status          String        @default("EXPECTED") // EXPECTED, RECEIVED, MISSING
  linkedItem      Item?         @relation(fields: [linkedItemId], references: [id])
  linkedItemId    Int?
  linkedSerial    SerialNumber? @relation(fields: [linkedSerialId], references: [id])
  linkedSerialId  Int?
  verifiedAt      DateTime?
  verifiedBy      String?
  createdAt       DateTime      @default(now())
}
